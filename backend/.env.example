# ── Supabase (REQUIRED) ──
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── Auth (REQUIRED) ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Azure AD ──
AZURE_CLIENT_ID=your-azure-app-client-id

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx

# ── Redis / Celery ──
REDIS_URL=redis://localhost:6379/0

# ── PostHog (error tracking) ──
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com

# ── AI (Pro plan, Claude Haiku) ──
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Telegram daily report + feedback alerts (optional) ──
# Daily summary at 14:00 UTC + instant alerts on user feedback.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Resend (transactional email — feedback forwarding) ──
# https://resend.com — verify domain, then set the API key.
RESEND_API_KEY=
RESEND_FROM_EMAIL=OutMass Feedback <support@getoutmass.com>
RESEND_TO_EMAIL=support@getoutmass.com

# ── App ──
BACKEND_URL=http://localhost:8000
FRONTEND_URL=chrome-extension://YOUR_EXTENSION_ID

# ── CORS (comma-separated, optional — defaults include localhost + extension) ──
# CORS_ORIGINS=chrome-extension://YOUR_ID,https://your-railway-domain.up.railway.app
